# Example environment variables for ParcelLink
# Copy this to .env and fill values (never commit .env)

PORT=3000
NODE_ENV=production
ADMIN_PASSWORD=ChangeMeStrong!
STAFF_PROVISION_KEY=ChangeMeProvisionKey!
AUTH_TOKEN_SECRET=ChangeMeAuthTokenSecret!
ALLOW_LEGACY_STAFF_LOGIN=false
AUTH_TOKEN_TTL_HOURS=24
ALLOWED_ORIGINS=http://localhost:3000

# Staff login credentials
# Default fallback password for all staff IDs (use a strong value)
# STAFF_PROVISION_KEY secures /api/staff/register (falls back to ADMIN_PASSWORD if omitted).
# Legacy static IDs (ADM001/INV001 etc.) are automatically disabled after first provisioned account,
# unless ALLOW_LEGACY_STAFF_LOGIN=true is explicitly set.
# You can optionally set per-staff passwords below.
# Example: STAFF_PASSWORD_ADM001=StrongUniquePassword!
# If STAFF_PASSWORD_<STAFF_ID> is set, it overrides ADMIN_PASSWORD for that staff account.

# Email (SMTP) - used for transactional and welcome emails
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=no-reply@parcellink.ae
EMAIL_FROM_NAME=ParcelLink
EMAIL_REPLY_TO=support@parcellink.ae

# DeepSeek AI translation (optional) - improves Arabic localization coverage
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_BATCH=30

# Database (Postgres)
# Option A: single URL (recommended for cloud providers)
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# Option B: explicit host config (useful for local development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=devpass
DB_NAME=parcellink
DB_SSL=false

# Optional per-staff password overrides (recommended for production)
# STAFF_PASSWORD_ADM001=parcel@1
# STAFF_PASSWORD_ADM002=
# STAFF_PASSWORD_DSP001=
# STAFF_PASSWORD_DSP002=
# STAFF_PASSWORD_WH001=
# STAFF_PASSWORD_WH002=
# STAFF_PASSWORD_CS001=
# STAFF_PASSWORD_CS002=
# STAFF_PASSWORD_FIN001=
# STAFF_PASSWORD_IT001=
# STAFF_PASSWORD_DRV001=
# STAFF_PASSWORD_DRV002=
# STAFF_PASSWORD_INV001=

# System user email for orphan parcel migration
SYSTEM_USER_EMAIL=system@parcellink.local

# Sentry (optional) for error monitoring
SENTRY_DSN=
